OPENAI_API_KEY=sk-...
OPENAI_AGENTS_DISABLE_TRACING=1

CHAT_TEMPLATE_ENV=development
CHAT_TEMPLATE_HOST=127.0.0.1
CHAT_TEMPLATE_PORT=8000
CHAT_TEMPLATE_PUBLIC_BASE_URL=http://127.0.0.1:8000
CHAT_TEMPLATE_DEFAULT_AGENT_ID=default
CHAT_TEMPLATE_DEFAULT_MODEL=gpt-5-mini
CHAT_TEMPLATE_SESSIONS_DB_PATH=.data/agent_sessions.sqlite3
CHAT_TEMPLATE_SESSION_HISTORY_LIMIT=40
CHAT_TEMPLATE_AGENTS_CONFIG_DIR=config/agents
